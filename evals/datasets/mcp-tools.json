{
  "name": "atlas-mcp-tools",
  "description": "Focused MCP tool behavior eval cases.",
  "repoId": "github.com/moxellabs/atlas",
  "cases": [
    {
      "id": "mcp-tools-find-docs-overview",
      "category": "mcp-tools",
      "query": "MCP find_docs overview: what Atlas docs explain finding docs and planning context over the local corpus?",
      "expected": {
        "pathIncludes": ["packages/mcp/docs/index.md", "docs/retrieval-and-context.md"],
        "terms": ["find_docs", "plan_context", "local corpus"],
        "tools": ["find_docs"]
      },
      "profile": "consumer",
      "feature": "mcp-find-docs",
      "scenario": "overview-query",
      "priority": "high"
    },
    {
      "id": "mcp-tools-plan-context-detail",
      "category": "mcp-tools",
      "query": "MCP plan_context detail query: explain Atlas local-first retrieval planning, token budgets, selected evidence, and provenance for agents.",
      "expected": {
        "pathIncludes": ["packages/retrieval/docs/index.md", "docs/retrieval-and-context.md"],
        "terms": ["token budgets", "provenance", "local-first"],
        "tools": ["plan_context"]
      },
      "profile": "agent-integrator",
      "feature": "mcp-plan-context",
      "scenario": "detail-query",
      "priority": "high"
    },
    {
      "id": "mcp-tools-read-section-exact",
