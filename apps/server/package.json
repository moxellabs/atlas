{
	"name": "@atlas/server",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "bun run --watch src/index.ts",
		"start": "bun src/index.ts",
		"typecheck": "bunx tsc --noEmit"
	},
	"dependencies": {
		"@atlas/config": "workspace:*",
		"@atlas/core": "workspace:*",
		"@atlas/indexer": "workspace:*",
		"@atlas/mcp": "workspace:*",
		"@atlas/retrieval": "workspace:*",
		"@atlas/store": "workspace:*",
		"@elysiajs/cors": "1.4.1",
		"@elysiajs/openapi": "1.4.14",
		"@elysiajs/opentelemetry": "1.4.11",
		"@elysiajs/server-timing": "1.4.0",
		"elysia": "1.4.28",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@elysiajs/eden": "1.4.9",
		"bun-types": "1.3.13"
	},
	"module": "src/index.ts",
	"exports": {
		".": "./src/app.ts",
		"./start-server": "./src/start-server.ts"
	},
	"types": "./src/app.ts",
	"files": [
		"src",
		"README.md"
	],
	"license": "AGPL-3.0-or-later",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/moxellabs/atlas.git"
	},
	"homepage": "https://github.com/moxellabs/atlas#readme",
	"bugs": {
		"url": "https://github.com/moxellabs/atlas/issues"
	},
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/moxellabs"
	},
	"description": "Private Atlas workspace package: @atlas/server."
}
