{
	"name": "@moxellabs/atlas",
	"private": false,
	"type": "module",
	"packageManager": "bun@1.3.11",
	"workspaces": [
		"apps/*",
		"packages/*",
		"tooling/*"
	],
	"scripts": {
		"dev": "bun --watch apps/server/src/index.ts",
		"dev:hot": "bun --hot apps/server/src/index.ts",
		"serve": "bun apps/server/src/index.ts",
		"cli": "bun apps/cli/src/index.ts",
		"verify": "bun tooling/scripts/verify.ts",
		"release:check": "bun tooling/scripts/release.ts --dry-run",
		"smoke:distribution": "bun tooling/scripts/distribution-smoke.ts",
		"typecheck": "bunx tsc --noEmit",
		"test": "bun test",
		"lint": "eslint .",
		"format": "prettier --write .",
		"build:package": "bun tooling/scripts/build-package.ts",
		"prepack": "bun run build:package"
	},
	"devDependencies": {
		"@ianvs/prettier-plugin-sort-imports": "4.7.1",
		"@types/bun": "1.3.12",
		"@types/micromatch": "^4.0.10",
		"@typescript-eslint/eslint-plugin": "8.59.0",
		"@typescript-eslint/parser": "8.59.0",
		"bun-types": "1.3.13",
		"eslint": "10.2.1",
		"prettier": "3.8.3",
		"typescript": "6.0.3"
	},
	"license": "AGPL-3.0-or-later",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/moxellabs/atlas.git"
	},
	"homepage": "https://github.com/moxellabs/atlas#readme",
	"bugs": {
		"url": "https://github.com/moxellabs/atlas/issues"
	},
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/moxellabs"
	},
	"version": "0.1.0",
	"description": "Local-first documentation ingestion, retrieval, and MCP/server access for multi-repo engineering docs.",
	"bin": {
		"atlas": "./bin/atlas"
	},
	"exports": {
		".": "./dist/atlas.js",
		"./commander": "./dist/commander.js"
	},
	"files": [
		"bin",
		"dist",
		"README.md",
		"LICENSE",
		"NOTICE",
		"SECURITY.md",
		".moxel/atlas",
		"docs",
		"!docs/archive/**",
		"!docs/prd/**",
		"!.planning/**",
		"!.github/**",
		"!tooling/**",
		"!**/*.test.ts",
		"!**/*.spec.ts"
	],
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"atlas",
		"documentation",
		"mcp",
		"retrieval",
		"local-first",
		"developer-tools"
	]
}
