      "versionNonce": 281272608,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Expected agent behavior: read manifest first; avoid retrieval for generic or sensitive prompts.\nScope the repo before retrieval; use plan_context for broad questions.\nRead exact sections for precise claims; call use_skill only for procedural skills.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Expected agent behavior: read manifest first; avoid retrieval for generic or sensitive prompts.\nScope the repo before retrieval; use plan_context for broad questions.\nRead exact sections for precise claims; call use_skill only for procedural skills.",
      "autoResize": false,
      "lineHeight": 1.25
